{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently -k -n renderer,electron \"npm run dev:renderer\" \"npm run dev:electron:local\"",
    "dev:renderer": "vite",
    "dev:electron": "npm run dev:electron:local",
    "dev:electron:local": "wait-on http://127.0.0.1:4173 && cross-env ELECTRON_RENDERER_URL=http://127.0.0.1:4173 CROSSPP_API_BASE_URL=http://127.0.0.1:3000 electron ./electron/main.js",
    "dev:electron:cloud": "wait-on http://127.0.0.1:4173 && cross-env ELECTRON_RENDERER_URL=http://127.0.0.1:4173 CROSSPP_API_BASE_URL=https://api.crosspp.ru electron ./electron/main.js",
    "start": "concurrently -k -n renderer,electron \"npm run dev:renderer\" \"npm run dev:electron:cloud\"",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "build:renderer": "vite build",
    "dist:win": "bun run build:renderer && electron-builder --win nsis"
  },
  "build": {
    "appId": "ru.crosspp.app",
    "productName": "CROSS++",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "electron/**",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": [
      {
        "provider": "github",
        "owner": "WamblyLA",
        "repo": "Cross-"
      }
    ]
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@reduxjs/toolkit": "^2.9.2",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "axios": "^1.12.2",
    "chokidar": "^5.0.0",
    "crypto": "^1.0.1",
    "crypto-browserify": "^3.12.1",
    "electron-updater": "^6.8.3",
    "katex": "^0.16.44",
    "monaco-editor": "^0.54.0",
    "node-pty": "^1.1.0",
    "plotly.js-dist-min": "^3.4.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-icons": "^5.5.0",
    "react-markdown": "^10.1.0",
    "react-redux": "^9.2.0",
    "react-router-dom": "^7.9.3",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.3",
    "autoprefixer": "^10.4.21",
    "baseline-browser-mapping": "^2.10.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^38.2.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.36.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.4.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.18",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.44.0",
    "vite": "^7.1.7",
    "wait-on": "^9.0.1"
  }
}

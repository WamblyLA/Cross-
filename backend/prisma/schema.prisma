generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProjectMemberRole {
  EDITOR
  VIEWER
}

enum ProjectInvitationStatus {
  PENDING
  ACCEPTED
  DECLINED
  REVOKED
}

enum NotificationType {
  PROJECT_INVITATION
}

model User {
  id                         String              @id @default(uuid()) @db.Uuid
  username                   String              @unique
  email                      String              @unique
  passwordHash               String
  createdAt                  DateTime            @default(now())
  updatedAt                  DateTime            @updatedAt
  projects                   Project[]
  projectLinks               ProjectLink[]
  projectMembers             ProjectMember[]
  sentProjectInvitations     ProjectInvitation[] @relation("ProjectInvitationInviter")
  receivedProjectInvitations ProjectInvitation[] @relation("ProjectInvitationInvitee")
  notifications              Notification[]
  settings                   UserSettings?
}

model Project {
  id           String              @id @default(uuid()) @db.Uuid
  ownerId      String              @db.Uuid
  name         String
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  owner        User                @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  folders      Folder[]
  files        File[]
  projectLinks ProjectLink[]
  members      ProjectMember[]
  invitations  ProjectInvitation[]

  @@index([ownerId])
}

model ProjectMember {
  id        String            @id @default(uuid()) @db.Uuid
  projectId String            @db.Uuid
  userId    String            @db.Uuid
  role      ProjectMemberRole
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  project   Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([projectId])
  @@index([userId])
}

model ProjectInvitation {
  id            String                  @id @default(uuid()) @db.Uuid
  projectId     String                  @db.Uuid
  inviterUserId String                  @db.Uuid
  inviteeUserId String                  @db.Uuid
  role          ProjectMemberRole
  status        ProjectInvitationStatus
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt
  respondedAt   DateTime?
  project       Project                 @relation(fields: [projectId], references: [id], onDelete: Cascade)
  inviter       User                    @relation("ProjectInvitationInviter", fields: [inviterUserId], references: [id], onDelete: Cascade)
  invitee       User                    @relation("ProjectInvitationInvitee", fields: [inviteeUserId], references: [id], onDelete: Cascade)
  notification  Notification?

  @@unique([projectId, inviteeUserId])
  @@index([projectId])
  @@index([inviteeUserId])
  @@index([inviterUserId])
  @@index([status])
}

model Folder {
  id        String    @id @default(uuid()) @db.Uuid
  projectId String    @db.Uuid
  parentId  String?   @db.Uuid
  name      String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parent    Folder?   @relation("FolderChildren", fields: [parentId], references: [id], onDelete: Cascade)
  children  Folder[]  @relation("FolderChildren")
  files     File[]

  @@index([projectId])
  @@index([parentId])
}

model File {
  id        String   @id @default(uuid()) @db.Uuid
  projectId String   @db.Uuid
  folderId  String?  @db.Uuid
  name      String
  content   String   @default("")
  version   Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  folder    Folder?  @relation(fields: [folderId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([folderId])
}

model UserSettings {
  userId   String   @id @db.Uuid
  theme    String   @default("dark")
  fontSize Int      @default(14)
  tabSize  Int      @default(4)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Notification {
  id                  String              @id @default(uuid()) @db.Uuid
  userId              String              @db.Uuid
  type                NotificationType
  readAt              DateTime?
  archivedAt          DateTime?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  projectInvitationId String?             @unique @db.Uuid
  user                User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectInvitation   ProjectInvitation?  @relation(fields: [projectInvitationId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([archivedAt])
  @@index([type])
}

model ProjectLink {
  id                String   @id @default(uuid()) @db.Uuid
  userId            String   @db.Uuid
  projectId         String   @db.Uuid
  clientBindingKey  String
  localRootLabel    String
  lastSyncAt        DateTime?
  lastSyncDirection String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project           Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, clientBindingKey])
  @@index([userId])
  @@index([projectId])
}
